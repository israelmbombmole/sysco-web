# Copy this file to ".env" in this folder (sysco-web) or in the directory you run Java from.
# ".env" is gitignored — do not commit API keys.
#
# Enables AI-assisted closure briefing and other optional assistants:
SYSCO_OPENAI_API_KEY=
# Optional overrides:
# SYSCO_OPENAI_MODEL=gpt-4o-mini
# SYSCO_OPENAI_BASE_URL=https://api.openai.com
